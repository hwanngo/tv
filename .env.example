# Backend bridge configuration. Copy to `.env` (which is gitignored) and fill in.
# The Go backend reads these as the default -m3u / -epg; docker compose loads them
# via env_file, and `make dev` sources them too.

# A playlist of udp:// channels for the bridge to serve. Empty = none (the app then
# uses iptv-org country lists, picked in Source settings — no server config needed).
IPTV_M3U=

# An XMLTV EPG URL for those channels. Empty = none.
IPTV_EPG=

# Host GID of the "render" group, so the container can use the iGPU for the VAAPI
# transcode (docker-compose group_add). Find it with: getent group render | cut -d: -f3
# Defaults to 110 if unset. Irrelevant if you run without -vaapi.
RENDER_GID=110
